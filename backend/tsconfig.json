{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },
    "outDir": "dist",
    "skipLibCheck": true,
    "importsNotUsedAsValues": "remove",
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*",
    "*.ts"
  ],
  "exclude": ["node_modules"]
}
